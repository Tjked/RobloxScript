-- Aimbot Target Logic
local function getTarget()
    local mouse = UserInputService:GetMouseLocation()
    local best, bd = nil, Settings.FOV
    
    local isSniper = false
    if LocalPlayer.Character then
        local tool = LocalPlayer.Character:FindFirstChildOfClass("Tool")
        if tool and tool.Name:lower():find("sniper") then isSniper = true end
    end

    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and isAlive(p) then
            local part = isSniper and getHead(p.Character) or getHRP(p.Character)
            if part then
                local ok, s, on = pcall(Camera.WorldToViewportPoint, Camera, part.Position)
                if ok and on then
                    local d = (Vector2.new(s.X, s.Y) - mouse).Magnitude
                    if d < bd then bd = d; best = part end
                end
            end
        end
    end
    return best
end

-- Triggerbot Logic
local function checkTriggerbot()
    if not Settings.Triggerbot then return end
    local mousePos = UserInputService:GetMouseLocation()
    local ray = Camera:ViewportPointToRay(mousePos.X, mousePos.Y)
    local hitPart = workspace:FindPartOnRayWithIgnoreList(Ray.new(ray.Origin, ray.Direction * 1000), {LocalPlayer.Character})
    
    if hitPart and hitPart.Parent then
        local model = hitPart.Parent:IsA("Model") and hitPart.Parent or hitPart.Parent.Parent
        local player = Players:GetPlayerFromCharacter(model)
        
        if player and player ~= LocalPlayer and isAlive(player) then
            -- Simulate Shoot
            mouse1press()
            task.wait(0.05)
            mouse1release()
        end
    end
end

