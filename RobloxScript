local tabs = {}
local function makeTab(name)
    local f = Instance.new("ScrollingFrame", content)
    f.Size = UDim2.new(1, 0, 1, 0); f.BackgroundTransparency = 1; f.BorderSizePixel = 0; f.Visible = false
    Instance.new("UIListLayout", f).Padding = UDim.new(0, 8)
    tabs[name] = f
end

local function makeTabBtn(name, i)
    local b = Instance.new("TextButton", sidebar)
    b.Size = UDim2.new(1, -10, 0, 32); b.Position = UDim2.new(0, 5, 0, 10 + (i-1)*38)
    b.BackgroundColor3 = Color3.fromRGB(30, 30, 30); b.Text = name; b.TextColor3 = Color3.new(0.7, 0.7, 0.7)
    Instance.new("UICorner", b)
    b.MouseButton1Click:Connect(function()
        for n, f in pairs(tabs) do f.Visible = (n == name) end
    end)
end

local function makeToggle(parent, label, setting)
    local b = Instance.new("TextButton", parent)
    b.Size = UDim2.new(1, -10, 0, 30); b.Text = label .. " [" .. (Settings[setting] and "ON" or "OFF") .. "]"
    b.BackgroundColor3 = Color3.fromRGB(35, 35, 35); b.TextColor3 = Color3.new(1, 1, 1)
    b.MouseButton1Click:Connect(function()
        Settings[setting] = not Settings[setting]
        b.Text = label .. " [" .. (Settings[setting] and "ON" or "OFF") .. "]"
    end)
end

makeTab("Visuals"); makeTab("Combat"); makeTab("Misc")
makeTabBtn("Visuals", 1); makeTabBtn("Combat", 2); makeTabBtn("Misc", 3)
makeToggle(tabs["Visuals"], "ESP", "ESP")
makeToggle(tabs["Visuals"], "Chams", "Chams")
makeToggle(tabs["Combat"], "Aimbot", "Aimbot")
makeToggle(tabs["Combat"], "Triggerbot", "Triggerbot")
tabs["Visuals"].Visible = true

-- ESP System
local drawFolder = Instance.new("Folder", gui)
local espObjs = {}

local function createESP(p)
    if p == LocalPlayer then return end
    local folder = Instance.new("Folder", drawFolder)
    local hl = Instance.new("Highlight", folder)
    hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    espObjs[p] = {hl = hl}
end

local function updateESP(p)
    local data = espObjs[p]
    if not data or not p.Character then return end
    local char = p.Character
    
    if Settings.Chams and isAlive(p) then
        data.hl.Enabled = true
        data.hl.Adornee = char
        local occ = isOccluded(char)
        local col = (p.Team == LocalPlayer.Team) and Color3.new(0, 0.6, 1) or (not occ and Color3.new(0, 1, 0) or Color3.new(1, 0, 0))
        data.hl.FillColor = col; data.hl.OutlineColor = col
        data.hl.FillTransparency = occ and (1 - Settings.ChamsAlpha * 0.5) or (1 - Settings.ChamsAlpha)
    else
        data.hl.Enabled = false
    end
end

-- Connections
local function onAdded(p)
    createESP(p)
    p.CharacterAdded:Connect(function() task.wait(1); createESP(p) end)
end

for _, p in ipairs(Players:GetPlayers()) do onAdded(p) end
Players.PlayerAdded:Connect(onAdded)
Players.PlayerRemoving:Connect(function(p) if espObjs[p] then espObjs[p].hl:Destroy(); espObjs[p] = nil end end)

UserInputService.InputBegan:Connect(function(inp)
    if inp.KeyCode == Settings.MenuKey then mainFrame.Visible = not mainFrame.Visible end
end)

-- Main Loop
RunService.RenderStepped:Connect(function()
    for _, p in ipairs(Players:GetPlayers()) do if p ~= LocalPlayer then updateESP(p) end end
    doTriggerbot()
    
    fovCircle.Visible = Settings.Aimbot and Settings.ShowFOV
    fovCircle.Radius = Settings.FOV
    fovCircle.Position = UserInputService:GetMouseLocation()
    
    if Settings.Aimbot and UserInputService:IsMouseButtonPressed(Settings.AimbotKey) then
        local tgt = getTarget()
        if tgt then
            local s = Camera:WorldToViewportPoint(tgt.Position)
            local m = UserInputService:GetMouseLocation()
            if mousemoverel then mousemoverel((s.X - m.X) * Settings.Smoothness, (s.Y - m.Y) * Settings.Smoothness) end
        end
    end
end)
