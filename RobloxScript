-- Main Render Loop
RunService.RenderStepped:Connect(function()
    for _,p in ipairs(Players:GetPlayers()) do
        if p~=LocalPlayer then updateESP(p) end
    end
    
    Camera.FieldOfView = Settings.ViewmodelFOV
    fovCircle.Visible = Settings.Aimbot and Settings.ShowFOV
    fovCircle.Radius = Settings.FOV
    fovCircle.Position = UserInputService:GetMouseLocation()
    
    -- Hybrid Key Detection (Keyboard or Mouse)
    local isPressed = false
    if Settings.AimbotKey.Name:find("MouseButton") then
        isPressed = UserInputService:IsMouseButtonPressed(Settings.AimbotKey)
    else
        isPressed = UserInputService:IsKeyDown(Settings.AimbotKey)
    end

    if Settings.Aimbot and isPressed then
        local tgt = getTarget()
        if tgt then
            local s = Camera:WorldToViewportPoint(tgt.Position)
            local m = UserInputService:GetMouseLocation()
            if mousemoverel then
                -- Smoothness now handles decimal multiplication
                mousemoverel((s.X-m.X)*Settings.Smoothness, (s.Y-m.Y)*Settings.Smoothness)
            end
        end
    end
end)

