-- OG Rivals Script | Roblox
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local Lighting = game:GetService("Lighting")
local Camera = workspace.CurrentCamera
local LocalPlayer = Players.LocalPlayer

local Settings = {
    ESP = true, ESPBoxes = true, ESPNames = true, ESPDistance = true, ESPHealth = true,
    Chams = true,
    ChamsAlpha = 0.4,
    Aimbot = true, Smoothness = 1, FOV = 150, ShowFOV = true,
    AimbotKey = Enum.UserInputType.MouseButton2,
    Triggerbot = true,
    TeamCheck = true,
    TriggerDelay = 0,
    ViewmodelFOV = 120,
    MenuKey = Enum.KeyCode.Insert,
    Noclip = false, InfiniteJump = false,
    Fly = false, FlySpeed = 50,
    NoFlash = true, NoSmoke = true,
}

local ACCENT = Color3.fromRGB(150, 200, 60)

-- Helpers
local function isAlive(p)
    local c = p.Character
    if not c then return false end
    local h = c:FindFirstChildWhichIsA("Humanoid")
    return h and h.Health > 0
end

local function getHRP(c)
    return c:FindFirstChild("HumanoidRootPart") or c:FindFirstChildWhichIsA("BasePart")
end

local function getHead(c)
    return c:FindFirstChild("HeadHB") or c:FindFirstChild("Head") or getHRP(c)
end

local function toScreen(pos)
    local ok, s, on = pcall(Camera.WorldToViewportPoint, Camera, pos)
    if not ok then return Vector2.new(), false end
    return Vector2.new(s.X, s.Y), on
end

-- Occlusion logic
local occCache, occTime = {}, {}
local function isOccluded(c)
    local now = tick()
    if occTime[c] and now - occTime[c] < 0.1 then return occCache[c] end
    local hrp = getHRP(c)
    if not hrp then return true end
    
    local origin = Camera.CFrame.Position
    local dir = hrp.Position - origin
    local ray = Ray.new(origin, dir)
    local hit = workspace:FindPartOnRayWithIgnoreList(ray, {c, LocalPlayer.Character, Camera})
    
    local occluded = hit ~= nil
    occCache[c] = occluded
    occTime[c] = now
    return occluded
end

-- Drawing FOV
local fovCircle = Drawing.new("Circle")
fovCircle.Thickness = 2; fovCircle.Filled = false
fovCircle.Color = ACCENT; fovCircle.Transparency = 0.6

-- Aimbot 90/10 Logic
local lastRoll = 0
local currentTargetName = "HumanoidRootPart"

local function getTarget()
    local mouse = UserInputService:GetMouseLocation()
    local best, bd = nil, Settings.FOV
    
    if tick() - lastRoll >= 0.1 then
        lastRoll = tick()
        currentTargetName = math.random(1, 100) <= 90 and "HumanoidRootPart" or "Head"
    end

    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and isAlive(p) and not isOccluded(p.Character) then
            if not (Settings.TeamCheck and p.Team == LocalPlayer.Team) then
                local part = p.Character:FindFirstChild(currentTargetName) or getHRP(p.Character)
                if part then
                    local pos, on = toScreen(part.Position)
                    if on then
                        local d = (pos - mouse).Magnitude
                        if d < bd then bd = d; best = part end
                    end
                end
            end
        end
    end
    return best
end

-- Triggerbot logic
local lastTrigger = 0
local function doTriggerbot()
    if not Settings.Triggerbot then return end
    if tick() - lastTrigger < (Settings.TriggerDelay or 0) then return end

    local mousePos = UserInputService:GetMouseLocation()
    local viewportRay = Camera:ViewportPointToRay(mousePos.X, mousePos.Y)
    
    local params = RaycastParams.new()
    params.FilterType = Enum.RaycastFilterType.Exclude
    params.FilterDescendantsInstances = {LocalPlayer.Character, Camera}
    
    local result = workspace:Raycast(viewportRay.Origin, viewportRay.Direction * 1000, params)
    if result and result.Instance then
        local model = result.Instance:FindFirstAncestorOfClass("Model")
        if model then
            local p = Players:GetPlayerFromCharacter(model)
            if p and p ~= LocalPlayer and isAlive(p) then
                if not (Settings.TeamCheck and p.Team == LocalPlayer.Team) then
                    lastTrigger = tick()
                    if mouse1click then mouse1click() end
                end
            end
        end
    end
end

