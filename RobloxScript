        for n, f in pairs(tabs) do f.Visible = (n == name) end
    end)
end

local function makeSlider(parent, label, setting, mn, mx, order, dec)
    local row = Instance.new("Frame", parent)
    row.Size = UDim2.new(1, -10, 0, 40); row.BackgroundTransparency = 1; row.LayoutOrder = order
    local lbl = Instance.new("TextLabel", row)
    lbl.Size = UDim2.new(1, 0, 0, 15); lbl.BackgroundTransparency = 1; lbl.TextColor3 = Color3.new(1,1,1)
    lbl.Font = Enum.Font.Gotham; lbl.TextSize = 12; lbl.TextXAlignment = Enum.TextXAlignment.Left
    
    local track = Instance.new("Frame", row)
    track.Size = UDim2.new(1, 0, 0, 8); track.Position = UDim2.new(0, 0, 0, 20); track.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
    local fill = Instance.new("Frame", track)
    fill.BackgroundColor3 = ACCENT; fill.BorderSizePixel = 0

    local function update()
        local input = UserInputService:GetMouseLocation()
        local pct = math.clamp((input.X - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
        local val = mn + (mx - mn) * pct
        if not dec then val = math.floor(val) end
        Settings[setting] = val
        lbl.Text = label .. ": " .. (dec and string.format("%.2f", val) or tostring(val))
        fill.Size = UDim2.new(pct, 0, 1, 0)
    end

    track.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then
            local move; move = RunService.RenderStepped:Connect(function()
                if UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton1) then update() else move:Disconnect() end
            end)
        end
    end)
    
    -- Initial set
    local initPct = (Settings[setting] - mn) / (mx - mn)
    fill.Size = UDim2.new(initPct, 0, 1, 0)
    lbl.Text = label .. ": " .. (dec and string.format("%.2f", Settings[setting]) or tostring(Settings[setting]))
end

local function makeToggle(parent, label, setting, order)
    local row = Instance.new("Frame", parent)
    row.Size = UDim2.new(1, -10, 0, 25); row.BackgroundTransparency = 1; row.LayoutOrder = order
    local btn = Instance.new("TextButton", row)
    btn.Size = UDim2.new(1, 0, 1, 0); btn.BackgroundTransparency = 1; btn.Text = label .. ": OFF"; btn.TextColor3 = Color3.new(0.6,0.6,0.6)
    btn.Font = Enum.Font.Gotham; btn.TextSize = 12; btn.TextXAlignment = Enum.TextXAlignment.Left
    btn.MouseButton1Click:Connect(function()
        Settings[setting] = not Settings[setting]
        btn.Text = label .. ": " .. (Settings[setting] and "ON" or "OFF")
        btn.TextColor3 = Settings[setting] and ACCENT or Color3.new(0.6,0.6,0.6)
    end)
end

