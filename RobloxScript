-- Updated ESP Logic for High FOV
local function updateESP(p)
    local t = espObjs[p]
    if not t then return end
    local char = p.Character
    if not char or not isAlive(p) then
        t.nl.Visible=false; t.dl.Visible=false; t.hbg.Visible=false; t.box.Visible=false; t.hl.Enabled=false
        return
    end

    local hrp = getHRP(char)
    if not hrp then return end

    local topPos = hrp.Position + Vector3.new(0, 3, 0)
    local botPos = hrp.Position - Vector3.new(0, 3.5, 0)
    local top, topVis = toScreen(topPos)
    local bot, botVis = toScreen(botPos)

    if topVis or botVis then
        local height = math.abs(top.Y - bot.Y)
        local width = height * 0.55
        
        -- Box
        if Settings.ESPBoxes then
            t.box.Visible = true
            t.box.Size = Vector2.new(width, height)
            t.box.Position = Vector2.new(top.X - width/2, top.Y)
        else t.box.Visible = false end

        -- Name
        if Settings.ESPNames then
            t.nl.Visible = true
            t.nl.Position = UDim2.new(0, top.X - 50, 0, top.Y - 20)
        else t.nl.Visible = false end

        -- Chams
        t.hl.Enabled = Settings.Chams
        t.hl.Adornee = char
    else
        t.nl.Visible=false; t.box.Visible=false; t.hl.Enabled=false
    end
end

-- Updated Decimal Slider
local function makeSlider(parent, label, setting, mn, mx, order, isDecimal)
    local row = Instance.new("Frame", parent)
    row.Size=UDim2.new(1,-10,0,44); row.BackgroundTransparency=1; row.LayoutOrder=order
    local lbl = Instance.new("TextLabel", row)
    lbl.Size=UDim2.new(1,0,0,16); lbl.BackgroundTransparency=1; lbl.TextColor3=Color3.new(1,1,1); lbl.Font=Enum.Font.Gotham; lbl.TextXAlignment=Enum.TextXAlignment.Left
    
    local track = Instance.new("Frame", row)
    track.Size=UDim2.new(1,0,0,10); track.Position=UDim2.new(0,0,0,22); track.BackgroundColor3=Color3.fromRGB(40,40,40)
    local fill = Instance.new("Frame", track)
    fill.BackgroundColor3=ACCENT; fill.Size=UDim2.new(0,0,1,0)

    local function update(input)
        local pos = math.clamp((input.Position.X - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
        local val = mn + ((mx - mn) * pos)
        if not isDecimal then val = math.floor(val) end
        Settings[setting] = val
        lbl.Text = label .. ": " .. (isDecimal and string.format("%.2f", val) or tostring(val))
        fill.Size = UDim2.new(pos, 0, 1, 0)
    end

    track.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            local conn; conn = RunService.RenderStepped:Connect(function()
                if UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton1) then
                    update(UserInputService:GetMouseLocation())
                else conn:Disconnect() end
            end)
        end
    end)
    -- Initial Set
    local startPos = (Settings[setting] - mn) / (mx - mn)
    fill.Size = UDim2.new(startPos, 0, 1, 0)
    lbl.Text = label .. ": " .. (isDecimal and string.format("%.2f", Settings[setting]) or tostring(Settings[setting]))
end

